{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "files": [
    "**/*.ps1",
    "**/*.psm1",
    "**/*.psd1",
    "**/*.md",
    "**/*.yml",
    "**/*.json",
    "**/*.jsonc",
  ],
  "useGitignore": true,
  "ignorePaths": [
    ".git/**",
    "LICENSE",
  ],
  "words": [
    "adminAdd",
    "Entra",
    "adminRemove",
    "EntraVac",
    "EntraVacuum",
    "Jeenil",
    "nextLink",
    "odata",
    "PSGallery",
    "PSGALLERY",
    "PSSA",
    "ConsistencyLevel",
    "extensionAttribute",
    "onPremisesExtensionAttributes",
    "requestorFilter",
    "ShouldProcess",
    "specificAllowedTargets",
  ],
}
